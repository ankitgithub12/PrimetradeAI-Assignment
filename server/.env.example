NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=your_mongodb_connection_string_here

# JWT
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRE=30d

# SendGrid (Requires Single Sender Verification)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=your_verified_sendgrid_email@domain.com
FROM_NAME=TaskFlow

# Frontend URL (Used for generating Reset Password email links)
# Update this to your deployed Frontend URL (e.g. https://task-flow-frontend.vercel.app)
CLIENT_URL=http://localhost:5173
